apiVersion: v1
kind: Secret
metadata:
  name: ecommerce-secrets
  namespace: ecommerce
type: Opaque
stringData:
  postgres-db: E_Commerence_DB
  postgres-user: postgres
  postgres-password: your_secure_password
  jwt-secret: your_jwt_secret_key
  admin-email: admin@vshop.com
  admin-password: admin123Pass
